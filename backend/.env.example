# 应用配置
APP_NAME=Atoms Demo
APP_VERSION=1.0.0
DEBUG=True

# 数据库配置
DATABASE_URL=sqlite+aiosqlite:///./atoms_demo.db

# AI 配置 - 阿里云 DashScope API
# 请替换为你的实际 API Key
AI_API_KEY=sk-your-api-key-here
AI_MODEL=qwen3.5-plus

# JWT 配置
# 生产环境请使用强随机密钥（例如：openssl rand -hex 32）
SECRET_KEY=your-secret-key-change-in-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=10080

# CORS 配置
CORS_ORIGINS=["http://localhost:5173","http://localhost:3000"]
